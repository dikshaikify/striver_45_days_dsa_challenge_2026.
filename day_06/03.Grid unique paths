class Solution {
    public int uniquePaths(int m, int n) {

        int[] dp = new int[n];

        Arrays.fill(dp, 1);

        for (int i = 1; i < m; i++) {
            for (int j = 1; j < n; j++) {

                // Left path: dp[j-1];
                // Top path: dp[j];
                // dp[j] is what we refer to for top when using temp array
                // dp[j] = left + top
                dp[j] += dp[j-1];
            }
        }

        return dp[n-1];
    }
}
