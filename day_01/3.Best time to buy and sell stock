class Solution {
    public int stockBuySell(int[] arr, int n) {

        int minPrice = arr[0];
        int maxProfit = 0;

        for (int i = 1; i < n; i++) {

            int profit = arr[i] - minPrice;

            maxProfit = Math.max(maxProfit, profit);

            minPrice = Math.min(minPrice, arr[i]);
        }

        return maxProfit;
    }
}
