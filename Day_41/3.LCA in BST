/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int data;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode(int val) {
 *         data = val;
 *         left = null;
 *         right = null;
 *     }
 * }
 **/

class Solution {
    public TreeNode lca(TreeNode root, int p, int q) {
        if (root == null)
            return null;

        if (p < root.data && q < root.data)
            return lca(root.left, p, q);

        if (p > root.data && q > root.data)
            return lca(root.right, p, q);

        return root;
    }
}
