import java.util.*;

class Solution {
    public int celebrity(int[][] M) {

        int n = M.length;

        Stack<Integer> st = new Stack<>();

        // Push all persons
        for (int i = 0; i < n; i++) {
            st.push(i);
        }

        // Eliminate non-celebrities
        while (st.size() > 1) {
            int a = st.pop();
            int b = st.pop();

            if (M[a][b] == 1) {
                st.push(b);
            } else {
                st.push(a);
            }
        }

        int candidate = st.pop();

        // Verify candidate
        for (int i = 0; i < n; i++) {

            if (i != candidate &&
                (M[candidate][i] == 1 || M[i][candidate] == 0)) {
                return -1;
            }
        }

        return candidate;
    }
}
